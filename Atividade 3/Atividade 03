import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# 🔹 Criando um dataset fake
dados = {
    'data': [
        '2024-01-10', '2024-01-15', '2024-02-10',
        '2024-02-20', '2024-03-05', '2024-03-18'
    ],
    'vendedor': ['Ana', 'Bruno', 'Ana', 'Carlos', 'Bruno', 'Ana'],
    'categoria': ['Eletrônicos', 'Roupas', 'Eletrônicos', 'Roupas', 'Alimentos', 'Eletrônicos'],
    'total_venda': [100, 250, 300, 150, 80, 400]
}

df = pd.DataFrame(dados)

print("📌 DataFrame inicial:")
print(df)

# -----------------------------------
# ✅ D1 - Faturamento mês a mês
# -----------------------------------
df['data'] = pd.to_datetime(df['data'])
df['mes'] = df['data'].dt.month

faturamento_mensal = df.groupby('mes')['total_venda'].sum()

print("\n📊 Faturamento mensal:")
print(faturamento_mensal)

# -----------------------------------
# ✅ D2 - Gráfico de linha
# -----------------------------------
