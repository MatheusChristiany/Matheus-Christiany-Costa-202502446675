# -----------------------------------
# ✅ D3 - Maior ticket médio
# -----------------------------------
ticket_medio = df.groupby('vendedor')['total_venda'].mean()

top_vendedor = ticket_medio.idxmax()
valor = ticket_medio.max()

print(f"\n🏆 Vendedor com maior ticket médio: {top_vendedor} ({valor})")

# -----------------------------------
# ✅ D4 - Vendas acima de 200
# -----------------------------------
vendas_altas = df[df['total_venda'] > 200]

analise_categoria = vendas_altas.groupby('categoria')['total_venda'].sum()

print("\n💰 Categorias com vendas acima de 200:")
print(analise_categoria)

# -----------------------------------
# ✅ D5 - Valores nulos
# -----------------------------------

# Adicionando linhas com nulos
linhas_nulas = pd.DataFrame({
    'data': [None]*3,
    'vendedor': [None]*3,
    'categoria': [None]*3,
    'total_venda': [None]*3
})

df = pd.concat([df, linhas_nulas], ignore_index=True)

print("\n🔍 Valores nulos:")
print(df.isnull().sum())

# Tratando nulos
df['total_venda'] = df['total_venda'].fillna(0)
df['vendedor'] = df['vendedor'].fillna('Desconhecido')
df['categoria'] = df['categoria'].fillna('Sem categoria')

print("\n✅ Dados tratados:")
print(df)
